---
/**
 * Custom Starlight footer override — flat single-line.
 *
 * Per the support redesign: drop the three-column layout (and the repeated
 * brand mark) so the footer reads as chrome rather than content. Copyright on
 * the left, Terms / Privacy / contact on the right.
 */
const year = new Date().getFullYear();
---

<footer class="fledge-footer">
	<span>© {year} Fledge Practice, Inc.</span>
	<span class="fledge-footer__links">
		<a href="https://fledgepractice.com/terms">Terms</a>
		<a href="https://fledgepractice.com/privacy">Privacy</a>
		<a href="mailto:admin@fledgepractice.com">admin@fledgepractice.com</a>
	</span>
</footer>

<style>
	.fledge-footer {
		margin-top: 4rem;
		padding: 1rem 0;
		border-top: 1px solid var(--sl-color-gray-5);
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-2);
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.fledge-footer__links {
		display: flex;
		gap: 1.25rem;
		flex-wrap: wrap;
	}

	.fledge-footer a {
		color: var(--sl-color-gray-2);
		text-decoration: none;
	}

	.fledge-footer a:hover {
		color: var(--sl-color-white);
		text-decoration: underline;
	}
</style>
