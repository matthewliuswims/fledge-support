---
/**
 * Custom Starlight PageTitle override.
 *
 * Prepends a Home › Category › Article breadcrumb above the page title on
 * non-home pages. The category label is mapped from the first slug segment
 * (e.g. `clients/adding-a-client` → "Clients") so the breadcrumb stays in
 * sync with the autogenerated sidebar groups in astro.config.mjs.
 */
// Mirrors '@astrojs/starlight/constants'.PAGE_TITLE_ID — kept in sync if it
// ever changes upstream. The constants module isn't a public export.
const PAGE_TITLE_ID = '_top';

const CATEGORY_LABELS: Record<string, string> = {
	'getting-started': 'Getting started',
	clients: 'Clients',
	'sessions-notes': 'Sessions & notes',
	'invoices-payments': 'Invoices & payments',
	'account-billing': 'Account & billing',
};

const { entry } = Astro.locals.starlightRoute;
const id = (entry.id ?? '').replace(/\.mdx?$/, '');
const isHome = id === '' || id === 'index';
const [categorySlug] = id.split('/');
const categoryLabel = !isHome && categorySlug ? CATEGORY_LABELS[categorySlug] : null;
---

{
	categoryLabel && (
		<nav class="fledge-breadcrumb" aria-label="Breadcrumb">
			<a href="/">Home</a>
			<span class="sep" aria-hidden="true">›</span>
			<span>{categoryLabel}</span>
			<span class="sep" aria-hidden="true">›</span>
			<span class="current">{entry.data.title}</span>
		</nav>
	)
}

<h1 id={PAGE_TITLE_ID}>{entry.data.title}</h1>

<style>
	h1 {
		margin-top: 1rem;
		font-size: var(--sl-text-h1);
		line-height: var(--sl-line-height-headings);
		font-weight: 600;
		color: var(--sl-color-white);
	}

	.fledge-breadcrumb {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 1rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
	}
	.fledge-breadcrumb + h1 {
		margin-top: 0.5rem;
	}
	.fledge-breadcrumb a {
		color: var(--sl-color-gray-2);
		text-decoration: none;
	}
	.fledge-breadcrumb a:hover {
		color: var(--sl-color-white);
	}
	.fledge-breadcrumb .sep {
		color: var(--sl-color-gray-4);
	}
	.fledge-breadcrumb .current {
		color: var(--sl-color-gray-1);
	}
</style>
